rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function exact(data, fields) { return data.keys().hasOnly(fields) && data.keys().hasAll(fields); }
    function validTicketKey(key) { return key is string && key.size() >= 11 && key.size() <= 934 && key.matches('^[A-Za-z0-9_-]+$'); }
    function journeyPath(id) { return /databases/$(database)/documents/journeys/$(id); }
    function claimPath(key) { return /databases/$(database)/documents/ticketClaims/$(key); }
    function payloadPath(key) { return /databases/$(database)/documents/privateTicketPayloads/$(key); }
    function userPath(uid) { return /databases/$(database)/documents/users/$(uid); }
    function leaderboardOwnerPath(id) { return /databases/$(database)/documents/leaderboardOwners/$(id); }
    function adminPath(uid) { return /databases/$(database)/documents/admins/$(uid); }
    function exploreFindPath(id) { return /databases/$(database)/documents/exploreFinds/$(id); }
    function exploreOwnerPath(id) { return /databases/$(database)/documents/exploreFindOwners/$(id); }
    function exploreEligibilityPath(uid) { return /databases/$(database)/documents/exploreEligibility/$(uid); }
    function exploreSubmissionPath(uid, id) { return /databases/$(database)/documents/users/$(uid)/exploreSubmissions/$(id); }
    function exploreInteractionPath(uid, id) { return /databases/$(database)/documents/users/$(uid)/exploreInteractions/$(id); }
    function enabledAdmin() {
      return signedIn() && exists(adminPath(request.auth.uid))
        && get(adminPath(request.auth.uid)).data.role == 'admin'
        && get(adminPath(request.auth.uid)).data.enabled == true;
    }
    function ownsExploreFind(id) {
      return signedIn() && exists(exploreOwnerPath(id))
        && get(exploreOwnerPath(id)).data.ownerUid == request.auth.uid;
    }
    function validStationId(id) {
      return id in ['aluva','pulinchodu','companypady','ambattukavu','muttom','kalamassery','cochin-university','pathadipalam','edapally','changampuzha-park','palarivattom','jln-stadium','kaloor','town-hall','mg-road','maharajas-college','ernakulam-south','kadavanthra','elamkulam','vyttila','thykoodam','petta','vadakkekotta','sn-junction','tripunithura-terminal'];
    }
    function validExploreFind(data) {
      return exact(data, ['schemaVersion','status','title','description','stationId','stationName','category','walkingMinutes','walkingTimeType','costType','bestTimes','environment','latitude','longitude','accessibilityNote','authorType','authorDisplayName','authorBadge','loveCount','seedVersion','verifiedAt','createdAt','updatedAt','publishedAt'])
        && data.schemaVersion == 1
        && data.status in ['pending','published','hidden','rejected','removed']
        && data.title is string && data.title.size() >= 3 && data.title.size() <= 70
        && data.description is string && data.description.size() >= 30 && data.description.size() <= 500
        && validStationId(data.stationId) && data.stationName is string && data.stationName.size() >= 2 && data.stationName.size() <= 70
        && data.category in ['food','park','culture','shopping','quick_activity','quiet_spot','photo_spot','museum','recreation','student_friendly','useful_service']
        && data.walkingMinutes is int && data.walkingMinutes >= 1 && data.walkingMinutes <= 25
        && data.walkingTimeType in ['verified','estimated']
        && data.costType in ['free','paid','varies','unknown']
        && data.bestTimes is list && data.bestTimes.size() <= 6
        && data.bestTimes.hasOnly(['morning','afternoon','evening','night','weekday','weekend'])
        && data.environment in ['indoor','outdoor','mixed','unknown']
        && data.latitude is number && data.latitude >= 9.85 && data.latitude <= 10.2
        && data.longitude is number && data.longitude >= 76.2 && data.longitude <= 76.45
        && (data.accessibilityNote == null || (data.accessibilityNote is string && data.accessibilityNote.size() <= 200))
        && data.authorType in ['veyro_team','local_explorer']
        && data.authorDisplayName is string && data.authorDisplayName.size() >= 1 && data.authorDisplayName.size() <= 30
        && data.authorBadge in ['Veyro Curated','Local Explorer']
        && data.loveCount is int && data.loveCount >= 0 && data.loveCount <= 10000000
        && (data.seedVersion == null || (data.seedVersion is int && data.seedVersion >= 1));
    }
    function validInteraction(data, id) {
      return exact(data, ['findId','saved','visited','hidden','reaction','firstSeenAt','savedAt','visitedAt','reactionAt','hiddenAt','updatedAt'])
        && data.findId == id && data.saved is bool && data.visited is bool && data.hidden is bool
        && (data.reaction == null || data.reaction in ['loved','not_for_me'])
        && (!data.visited ? data.reaction == null : true)
        && data.updatedAt == request.time;
    }
    function validLeaderboardId(id) { return id is string && id.size() == 36 && id.matches('^[0-9a-f-]+$'); }
    function validLeaderboardEntry(data) {
      return exact(data, ['visible','displayName','displayNameNormalized','photoURL','showPhoto','totalJourneys','totalDistanceKm','longestStreak','statsVersion','joinedAt','updatedAt'])
        && data.visible is bool
        && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 30
        && data.displayNameNormalized is string && data.displayNameNormalized.size() >= 1 && data.displayNameNormalized.size() <= 30
        && data.showPhoto is bool
        && ((!data.showPhoto && data.photoURL == null) || (data.showPhoto && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048))))
        && data.totalJourneys is int && data.totalJourneys >= 0 && data.totalJourneys <= 100000
        && data.totalDistanceKm is number && data.totalDistanceKm >= 0 && data.totalDistanceKm <= 10000000
        && data.longestStreak is int && data.longestStreak >= 0 && data.longestStreak <= 10000
        && data.statsVersion == 1;
    }
    function ownsLeaderboard(id) {
      return signedIn() && exists(leaderboardOwnerPath(id))
        && get(leaderboardOwnerPath(id)).data.ownerUid == request.auth.uid;
    }

    match /users/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create: if signedIn() && request.auth.uid == uid
        && exact(request.resource.data, ['uid','displayName','email','photoURL','createdAt','lastSeenAt'])
        && request.resource.data.uid == uid && request.resource.data.email is string
        && request.resource.data.displayName is string
        && (request.resource.data.photoURL == null || request.resource.data.photoURL is string)
        && request.resource.data.createdAt == request.time && request.resource.data.lastSeenAt == request.time;
      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName','photoURL','lastSeenAt','leaderboardId'])
        && request.resource.data.displayName is string
        && (request.resource.data.photoURL == null || request.resource.data.photoURL is string)
        && request.resource.data.lastSeenAt == request.time
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['leaderboardId'])
          || (!resource.data.keys().hasAny(['leaderboardId'])
            && validLeaderboardId(request.resource.data.leaderboardId)
            && existsAfter(leaderboardOwnerPath(request.resource.data.leaderboardId))
            && getAfter(leaderboardOwnerPath(request.resource.data.leaderboardId)).data.ownerUid == request.auth.uid));
      allow delete: if false;

      match /exploreInteractions/{findId} {
        allow get, list: if signedIn() && request.auth.uid == uid;
        allow create, update: if signedIn() && request.auth.uid == uid
          && validInteraction(request.resource.data, findId);
        allow delete: if signedIn() && request.auth.uid == uid;
      }

      match /exploreSubmissions/{findId} {
        allow get, list: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn() && request.auth.uid == uid
          && exact(request.resource.data, ['findId','title','stationId','stationName','status','moderationMessage','createdAt','updatedAt'])
          && request.resource.data.findId == findId
          && request.resource.data.status == 'pending'
          && request.resource.data.moderationMessage == null
          && request.resource.data.createdAt == request.time && request.resource.data.updatedAt == request.time
          && existsAfter(exploreFindPath(findId))
          && existsAfter(exploreOwnerPath(findId))
          && getAfter(exploreOwnerPath(findId)).data.ownerUid == uid;
        allow update: if enabledAdmin()
          || (signedIn() && request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title','stationId','stationName','status','moderationMessage','updatedAt'])
            && request.resource.data.status in ['pending','removed']
            && request.resource.data.moderationMessage == null
            && request.resource.data.updatedAt == request.time);
        allow delete: if false;
      }
    }

    match /leaderboardOwners/{leaderboardId} {
      allow get: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow list: if false;
      allow create: if signedIn() && validLeaderboardId(leaderboardId)
        && !exists(leaderboardOwnerPath(leaderboardId))
        && exact(request.resource.data, ['ownerUid','createdAt'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && existsAfter(userPath(request.auth.uid))
        && getAfter(userPath(request.auth.uid)).data.leaderboardId == leaderboardId;
      allow update, delete: if false;
    }

    match /leaderboardEntries/{leaderboardId} {
      allow get: if resource.data.visible == true || ownsLeaderboard(leaderboardId);
      allow list: if resource.data.visible == true;
      allow create: if signedIn() && validLeaderboardId(leaderboardId)
        && !exists(/databases/$(database)/documents/leaderboardEntries/$(leaderboardId))
        && existsAfter(leaderboardOwnerPath(leaderboardId))
        && getAfter(leaderboardOwnerPath(leaderboardId)).data.ownerUid == request.auth.uid
        && validLeaderboardEntry(request.resource.data)
        && request.resource.data.joinedAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if ownsLeaderboard(leaderboardId)
        && validLeaderboardEntry(request.resource.data)
        && request.resource.data.joinedAt == resource.data.joinedAt
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /journeys/{journeyId} {
      allow get, list: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if signedIn()
        && exact(request.resource.data, ['ownerUid','fromStationId','fromStationName','toStationId','toStationName','stationIntervals','distanceKm','scannedAt','ocrConfidence','ticketReference','createdAt'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.fromStationId is string && request.resource.data.fromStationId.size() > 0
        && request.resource.data.toStationId is string && request.resource.data.toStationId.size() > 0
        && request.resource.data.fromStationId != request.resource.data.toStationId
        && request.resource.data.fromStationName is string && request.resource.data.fromStationName.size() > 0
        && request.resource.data.toStationName is string && request.resource.data.toStationName.size() > 0
        && request.resource.data.stationIntervals is int && request.resource.data.stationIntervals >= 1 && request.resource.data.stationIntervals <= 30
        && request.resource.data.distanceKm is number && request.resource.data.distanceKm > 0 && request.resource.data.distanceKm <= 50
        && request.resource.data.ocrConfidence is number && request.resource.data.ocrConfidence >= 0.72 && request.resource.data.ocrConfidence <= 1
        && validTicketKey(request.resource.data.ticketReference)
        && request.resource.data.scannedAt == request.time && request.resource.data.createdAt == request.time
        && !exists(claimPath(request.resource.data.ticketReference))
        && existsAfter(claimPath(request.resource.data.ticketReference))
        && existsAfter(payloadPath(request.resource.data.ticketReference))
        && getAfter(payloadPath(request.resource.data.ticketReference)).data.journeyId == journeyId
        && getAfter(payloadPath(request.resource.data.ticketReference)).data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /ticketClaims/{ticketKey} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn() && validTicketKey(ticketKey) && !exists(claimPath(ticketKey))
        && exact(request.resource.data, ['claimed','createdAt'])
        && request.resource.data.claimed == true && request.resource.data.createdAt == request.time
        && existsAfter(payloadPath(ticketKey))
        && getAfter(payloadPath(ticketKey)).data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /privateTicketPayloads/{ticketKey} {
      allow read: if false;
      allow create: if signedIn() && validTicketKey(ticketKey) && !exists(payloadPath(ticketKey))
        && exact(request.resource.data, ['rawQrValue','ownerUid','journeyId','fromStationId','toStationId','scannedAt'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.rawQrValue is string && request.resource.data.rawQrValue.size() >= 8 && request.resource.data.rawQrValue.size() <= 700
        && request.resource.data.journeyId is string && request.resource.data.fromStationId is string && request.resource.data.toStationId is string
        && request.resource.data.fromStationId != request.resource.data.toStationId
        && request.resource.data.scannedAt == request.time
        && !exists(claimPath(ticketKey)) && existsAfter(claimPath(ticketKey))
        && existsAfter(journeyPath(request.resource.data.journeyId))
        && getAfter(journeyPath(request.resource.data.journeyId)).data.ownerUid == request.auth.uid
        && getAfter(journeyPath(request.resource.data.journeyId)).data.ticketReference == ticketKey
        && getAfter(journeyPath(request.resource.data.journeyId)).data.fromStationId == request.resource.data.fromStationId
        && getAfter(journeyPath(request.resource.data.journeyId)).data.toStationId == request.resource.data.toStationId;
      allow update, delete: if false;
    }

    match /admins/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || enabledAdmin());
      allow list: if enabledAdmin();
      allow create, update, delete: if false;
    }

    match /exploreEligibility/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create, update: if signedIn() && request.auth.uid == uid
        && exact(request.resource.data, ['totalJourneys','totalDistanceKm','eligible','statsVersion','calculatedAt'])
        && request.resource.data.totalJourneys is int && request.resource.data.totalJourneys >= 0 && request.resource.data.totalJourneys <= 100000
        && request.resource.data.totalDistanceKm is number && request.resource.data.totalDistanceKm >= 0 && request.resource.data.totalDistanceKm <= 10000000
        && request.resource.data.eligible == (request.resource.data.totalJourneys >= 5 && request.resource.data.totalDistanceKm >= 25)
        && request.resource.data.statsVersion == 1 && request.resource.data.calculatedAt == request.time;
      allow delete: if false;
    }

    match /exploreFindOwners/{findId} {
      allow get: if signedIn() && (resource.data.ownerUid == request.auth.uid || enabledAdmin());
      allow list: if enabledAdmin();
      allow create: if signedIn() && !exists(exploreOwnerPath(findId))
        && exact(request.resource.data, ['ownerUid','origin','createdAt'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.origin in ['community','admin']
        && request.resource.data.createdAt == request.time
        && existsAfter(exploreFindPath(findId))
        && (
          (request.resource.data.origin == 'community'
            && getAfter(exploreFindPath(findId)).data.status == 'pending'
            && existsAfter(exploreSubmissionPath(request.auth.uid, findId)))
          ||
          (request.resource.data.origin == 'admin'
            && enabledAdmin()
            && getAfter(exploreFindPath(findId)).data.status == 'published'
            && getAfter(exploreFindPath(findId)).data.authorType == 'veyro_team')
        );
      allow update, delete: if false;
    }

    match /exploreFinds/{findId} {
      allow get: if signedIn() && (resource.data.status == 'published' || enabledAdmin() || ownsExploreFind(findId));
      allow list: if signedIn() && (resource.data.status == 'published' || enabledAdmin());
      allow create: if signedIn() && validExploreFind(request.resource.data)
        && (
          (enabledAdmin() && request.resource.data.status == 'published'
            && request.resource.data.authorType == 'veyro_team'
            && request.resource.data.authorBadge == 'Veyro Curated')
          ||
          (exists(exploreEligibilityPath(request.auth.uid))
            && get(exploreEligibilityPath(request.auth.uid)).data.eligible == true
            && get(exploreEligibilityPath(request.auth.uid)).data.totalJourneys >= 5
            && get(exploreEligibilityPath(request.auth.uid)).data.totalDistanceKm >= 25
            && request.resource.data.status == 'pending'
            && request.resource.data.authorType == 'local_explorer'
            && request.resource.data.authorBadge == 'Local Explorer'
            && request.resource.data.loveCount == 0
            && request.resource.data.publishedAt == null
            && request.resource.data.verifiedAt == null
            && existsAfter(exploreOwnerPath(findId))
            && getAfter(exploreOwnerPath(findId)).data.ownerUid == request.auth.uid
            && existsAfter(exploreSubmissionPath(request.auth.uid, findId)))
        )
        && request.resource.data.createdAt == request.time && request.resource.data.updatedAt == request.time;
      allow update: if enabledAdmin() && validExploreFind(request.resource.data)
        || (ownsExploreFind(findId) && validExploreFind(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','title','description','stationId','stationName','category','walkingMinutes','walkingTimeType','costType','bestTimes','environment','latitude','longitude','accessibilityNote','updatedAt'])
          && request.resource.data.status in ['pending','removed']
          && request.resource.data.authorType == resource.data.authorType
          && request.resource.data.authorBadge == resource.data.authorBadge
          && request.resource.data.authorDisplayName == resource.data.authorDisplayName
          && request.resource.data.loveCount == resource.data.loveCount
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.publishedAt == resource.data.publishedAt
          && request.resource.data.updatedAt == request.time)
        || (signedIn() && resource.data.status == 'published'
          && validExploreFind(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['loveCount','updatedAt'])
          && request.resource.data.updatedAt == request.time
          && exists(exploreInteractionPath(request.auth.uid, findId))
          && existsAfter(exploreInteractionPath(request.auth.uid, findId))
          && getAfter(exploreInteractionPath(request.auth.uid, findId)).data.visited == true
          && (
            (get(exploreInteractionPath(request.auth.uid, findId)).data.reaction != 'loved'
              && getAfter(exploreInteractionPath(request.auth.uid, findId)).data.reaction == 'loved'
              && request.resource.data.loveCount == resource.data.loveCount + 1)
            ||
            (get(exploreInteractionPath(request.auth.uid, findId)).data.reaction == 'loved'
              && getAfter(exploreInteractionPath(request.auth.uid, findId)).data.reaction != 'loved'
              && request.resource.data.loveCount == resource.data.loveCount - 1
              && request.resource.data.loveCount >= 0)
          ));
      allow delete: if false;
    }

    match /exploreReports/{reportId} {
      allow get: if enabledAdmin() || (signedIn() && resource.data.reporterUid == request.auth.uid);
      allow list: if enabledAdmin();
      allow create: if signedIn()
        && exact(request.resource.data, ['findId','reporterUid','reason','details','status','createdAt','reviewedAt'])
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reason in ['place_closed','incorrect_location','unsafe_or_restricted','misleading_description','advertisement','private_information','other']
        && (request.resource.data.details == null || (request.resource.data.details is string && request.resource.data.details.size() <= 300))
        && request.resource.data.status == 'open' && request.resource.data.createdAt == request.time && request.resource.data.reviewedAt == null
        && exists(exploreFindPath(request.resource.data.findId));
      allow update: if enabledAdmin();
      allow delete: if false;
    }

    match /exploreSourceRecords/{findId} {
      allow read, write: if enabledAdmin();
    }

    match /stations/{stationId} { allow read: if true; allow write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
